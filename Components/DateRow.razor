@using System.Globalization
@if (Updated.HasValue)
{
    @DateInRow("Updated", Updated.Value)
}
@DateInRow(string.Empty, Published)
@code {
    [Parameter, EditorRequired] public DateTime Published { get; set; }
    [Parameter, EditorRequired] public DateTime? Updated { get; set; }

    RenderFragment DateInRow(string label, DateTime date) => @<dd class="text-base font-medium leading-6 text-gray-400">
    @if (label != string.Empty)
    {
                <span class="mr-2 text-xs uppercase tracking-wide text-gray-500">@label</span>
    }
                <time datetime="@date.ToString("yyyy-MM-ddTHH:mm:ss.fffK", CultureInfo.InvariantCulture)">
                    @date.ToString("MMMM d, yyyy", new CultureInfo("en-US"))
                </time>
            </dd>;
}
